---
config:
  layout: elk
---
flowchart TB
    ClientApp(["Client Applications (Web/Mobile UIs)"])
    AIAgents[/"🤖 AI Agents"\]
    subgraph SystemEnvironment ["Ledger Nova Backend Environment"]
        direction TB
        LedgerNovaApp["LedgerNova Core API (Node & TypeScript)"]
        subgraph DataLayer ["Persistence & Caching"]
            direction LR
            Postgres[(PostgreSQL)]
            Redis[(Redis)]
            S3Bucket[(AWS S3)]
        end
        
        LedgerNovaApp -- "TCP/IP (SQL)" --> Postgres
        LedgerNovaApp -- "TCP/IP (Redis Protocol)" --> Redis
        LedgerNovaApp -- "HTTPS (AWS SDK)" --> S3Bucket
    end
    ClientApp -- "HTTPS (REST/GraphQL)" --> LedgerNovaApp
    AIAgents -- "HTTPS/Stdio (MCP)" --> LedgerNovaApp
    subgraph ExternalServices ["External Cloud Services"]
        direction LR
        TaxProMax["FIRS Tax ProMax (Tax Portal API)"]
        Mono["Mono API (Open Banking)"]
        ZeptoMail["ZeptoMail API (Email Service)"]
        Paystack["Paystack API (Payment Gateway)"]
    end
    
    LedgerNovaApp -- "HTTPS (REST)" --> TaxProMax
    LedgerNovaApp -- "HTTPS (REST)" --> Mono
    LedgerNovaApp -- "HTTPS (SMTP/REST)" --> ZeptoMail
    LedgerNovaApp -- "HTTPS (REST)" --> Paystack
    style LedgerNovaApp fill:#333,stroke:#fff,color:#fff
    style ClientApp fill:#f4f4f4,stroke:#333
    style AIAgents fill:#009688,color:#fff,stroke:#333
    style Postgres fill:#336791,color:#fff,stroke:#fff
    style Redis fill:#dc382d,color:#fff,stroke:#fff
    style SystemEnvironment fill:#757575,stroke:#fff,stroke-width:2px,color:#fff
    style DataLayer fill:#555,stroke:#fff,stroke-width:1px,color:#fff