{
  "openapi": "3.0.0",
  "components": {
    "examples": {},
    "headers": {},
    "parameters": {},
    "requestBodies": {},
    "responses": {},
    "schemas": {
      "UAccountingEntityType": {
        "type": "string",
        "enum": ["individual", "sole_trader", "company"]
      },
      "UCategoryType": {
        "type": "string",
        "enum": [
          "expense",
          "sale",
          "purchase",
          "credit_note",
          "debit_note",
          "payment",
          "receipt"
        ]
      },
      "UCategoryStatus": {
        "type": "string",
        "enum": ["active", "archived"]
      },
      "ICategory": {
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "accountingEntityType": {
            "$ref": "#/components/schemas/UAccountingEntityType"
          },
          "type": {
            "$ref": "#/components/schemas/UCategoryType"
          },
          "taxKey": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/UCategoryStatus"
          },
          "description": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "createdBy": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "accountingEntityType",
          "type",
          "taxKey",
          "status",
          "description",
          "parentId",
          "createdBy",
          "createdAt",
          "updatedAt",
          "deletedAt"
        ],
        "type": "object",
        "additionalProperties": false
      },
      "ULedgerType": {
        "type": "string",
        "enum": ["asset", "liability", "revenue", "expense", "equity"]
      },
      "UJournalDirection": {
        "type": "string",
        "enum": ["debit", "credit"]
      },
      "IApiValidationError": {
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["field", "message"],
        "type": "object",
        "additionalProperties": false
      },
      "IApiError": {
        "properties": {
          "message": {
            "type": "string"
          },
          "validationErrors": {
            "items": {
              "$ref": "#/components/schemas/IApiValidationError"
            },
            "type": "array"
          },
          "cause": {}
        },
        "required": ["message"],
        "type": "object",
        "additionalProperties": false
      },
      "IIndividualSignupReq": {
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": ["firstName", "lastName", "email", "password"],
        "type": "object",
        "additionalProperties": false
      }
    },
    "securitySchemes": {}
  },
  "info": {
    "title": "ledgernova-core",
    "version": "1.0.0",
    "description": "This repo contains the server-side source code for Purple Ledger's bookkeeping and tax app.",
    "license": {
      "name": "AGPL-3.0-or-later"
    },
    "contact": {
      "name": "Osahon Oboite"
    }
  },
  "paths": {
    "/currencies": {
      "get": {
        "operationId": "getCurrencies",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "symbol": {
                        "type": "string"
                      },
                      "code": {
                        "type": "string"
                      },
                      "minorUnit": {
                        "type": "number",
                        "format": "double"
                      }
                    },
                    "required": ["name", "symbol", "code", "minorUnit"],
                    "type": "object"
                  },
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Get Currencies",
        "tags": ["Currency"],
        "security": [],
        "parameters": []
      }
    },
    "/categories": {
      "get": {
        "operationId": "getCategories",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ICategory"
                  },
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Gets the categories for an individual, sole trader or organization.",
        "tags": ["Category"],
        "security": [],
        "parameters": [
          {
            "in": "header",
            "name": "x-accounting-entity-type",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/UAccountingEntityType"
            }
          },
          {
            "in": "query",
            "name": "ledgerType",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/ULedgerType"
            }
          },
          {
            "in": "query",
            "name": "transactionDirection",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/UJournalDirection"
            }
          }
        ]
      }
    },
    "/auth/signup-with-email": {
      "post": {
        "operationId": "signupWithEmail",
        "responses": {
          "201": {
            "description": ""
          },
          "400": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IApiError"
                }
              }
            }
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IApiError"
                }
              }
            }
          },
          "409": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IApiError"
                }
              }
            }
          },
          "422": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IApiError"
                }
              }
            }
          },
          "500": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IApiError"
                }
              }
            }
          }
        },
        "description": "User signup with email and password",
        "tags": ["Auth"],
        "security": [],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IIndividualSignupReq"
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ]
}
