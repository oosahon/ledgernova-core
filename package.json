{
  "name": "ledgernova-core",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:ci": "bash bin/test-ci.sh",
    "start": "node ./dist/src/app/bootstrap/index.js",
    "start:test": "bash bin/test.sh",
    "start:postgres": "bash bin/start-postgres.sh",
    "start:redis": "bash bin/redis-setup.sh",
    "dev": "bash bin/dev.sh",
    "format:all": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:changed": "prettier --write --cache .",
    "build": "tsoa spec-and-routes && tsc",
    "build:routes": "tsoa spec-and-routes ",
    "drizzle:pull": "drizzle-kit pull",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org purpleledger --project node-express ./dist && sentry-cli sourcemaps upload --org purpleledger --project node-express ./dist",
    "prepare": "husky",
    "email:build": "node bin/mjml-to-html.js",
    "adr:add": "tsx bin/add-adr.ts",
    "adr:remove": "tsx bin/remove-adr.ts",
    "adr:rename": "tsx bin/rename-adr.ts",
    "adr:sync": "tsx bin/sync-adr.ts"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "keywords": [],
  "author": "Osahon Oboite",
  "license": "AGPL-3.0-or-later",
  "description": "This repo contains the server-side source code for Purple Ledger's bookkeeping and tax app.",
  "bin": {
    "purple-ledger-be": "bin/api-gen.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/pg": "^8.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "swagger-typescript-api": "^13.6.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
