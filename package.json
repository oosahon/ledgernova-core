{
  "name": "purple-ledger-be",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:ci": "bash bin/test-ci.sh",
    "start": "npm run db:migrate && node ./dist/src/index.js",
    "start:test": "bash bin/test.sh",
    "start:postgres": "bash bin/pg-setup.sh",
    "start:redis": "bash bin/redis-setup.sh",
    "dev": "bash bin/dev.sh",
    "format:all": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:changed": "prettier --write --cache .",
    "build": "tsoa spec-and-routes && tsc && yarn sentry:sourcemaps",
    "build:routes": "tsoa spec-and-routes ",
    "drizzle:pull": "drizzle-kit pull",
    "db:seed:generate": "node bin/generate-seed-file.js",
    "db:seed": "ts-node src/infra/db/seeds/index.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org purpleledger --project node-express ./dist && sentry-cli sourcemaps upload --org purpleledger --project node-express ./dist",
    "prepare": "husky",
    "email:build": "node bin/mjml-to-html.js"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "keywords": [],
  "author": "Osahon Oboite",
  "license": "ISC",
  "description": "This repo contains the server-side source code for Purple Ledger's bookkeeping and tax app.",
  "bin": {
    "purple-ledger-be": "bin/api-gen.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0"
  }
}
